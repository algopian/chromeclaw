{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ChromeClaw",
  "description": "AI agent running entirely in the Chrome browser sandbox — with multi-provider LLM support, messaging channels, voice, memory, agents, and browser automation.",
  "theme": "mint",
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/assets/chromeclaw-logo.svg",
    "dark": "/assets/chromeclaw-logo.svg"
  },
  "favicon": "/assets/chromeclaw-logo.svg",
  "colors": {
    "primary": "#FF5A36",
    "dark": "#FF5A36",
    "light": "#FF8A6B"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "min-dark",
        "light": "min-light"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/algopian/chromeclaw",
        "icon": "github"
      },
      {
        "label": "Chrome Web Store",
        "href": "https://chromewebstore.google.com/detail/chromeclaw-your-own-perso/lnahopfgnfhcfchffbckmbbkopcmojme",
        "icon": "chrome"
      },
      {
        "label": "Firefox Add-ons",
        "href": "https://addons.mozilla.org/addon/chromeclaw/",
        "icon": "firefox"
      }
    ]
  },
  "tabs": [
    {
      "tab": "Get Started",
      "groups": [
        {
          "group": "Home",
          "pages": ["index"]
        },
        {
